## Create `.env` before running `docker compose up -d`

# This environment variable is required, you can obtain tunnel token via Cloudflare -> Zero Trust -> Network -> Connectors.
# Or via Cloudflare's REST API: https://developers.cloudflare.com/cloudflare-one/networks/connectors/cloudflare-tunnel/get-started/create-remote-tunnel-api/
TUNNEL_TOKEN=your_long_token_here_xxxxxxxxx

# Required for domain registration validation.
# Add a space between each domain, for example: "example.com demo.net"
DOMAINS=

# This environment variable is required for you to use the PostgreSQL image.
# It must not be empty or undefined. This environment variable sets the superuser password for PostgreSQL.
# The default superuser is defined by the POSTGRES_USER environment variable.
POSTGRES_PASSWORD=

# Optional. Creates the given user and a database with the same name.
POSTGRES_USER=

# Optional. If omitted, Postgres uses POSTGRES_USER.
POSTGRES_DB=

# Optional. Use this if Postgres is hosted outside Docker.
POSTGRES_URL=

# GitHub OAuth App credentials from https://github.com/settings/applications/new

# Required for GitHub authentication.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional comma-separated GitHub user IDs with admin access.
# Example lookup: curl -s https://api.github.com/users/octocat | grep -w "id"
ADMIN_IDS=

# Public URLs used by the frontend and OAuth callbacks.
WEBSITE_URL=http://localhost:5173

# Required JWT secret used to sign session tokens.
JWT_SECRET=
